		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"flowcraft": "^2.10.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260524.1",
		"@vitest/coverage-v8": "^4.1.7",
		"miniflare": "^4.20260521.0",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	}
}
