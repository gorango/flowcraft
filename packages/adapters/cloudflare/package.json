{
	"name": "@flowcraft/cloudflare-adapter",
	"version": "1.0.2",
	"homepage": "https://flowcraft.js.org",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
