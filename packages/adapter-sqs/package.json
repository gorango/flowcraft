{
	"name": "@flowcraft/sqs-adapter",
	"type": "module",
	"version": "1.4.2",
	"homepage": "https://flowcraft.js.org",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "./testcontainers.sh && vitest run src/*.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.1000.0",
		"@aws-sdk/client-sqs": "^3.1000.0",
		"@aws-sdk/lib-dynamodb": "^3.1000.0",
		"@aws-sdk/util-dynamodb": "^3.996.1",
		"flowcraft": "^2.7.1",
		"sqs-consumer": "^14.2.2"
	},
	"devDependencies": {
		"@testcontainers/localstack": "^11.12.0",
		"aws-sdk-client-mock": "^4.1.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
