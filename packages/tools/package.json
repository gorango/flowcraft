{
	"name": "@flowcraft/tools",
	"version": "0.1.0",
	"description": "AI agent tools for composing, orchestrating, and executing Flowcraft workflows",
	"keywords": [
		"agentic-workflows",
		"ai-agents",
		"ai-tools",
		"flowcraft",
		"langchain",
		"llm-orchestration",
		"vercel-ai"
	],
	"homepage": "https://flowcraft.js.org",
	"bugs": "https://github.com/gorango/flowcraft/issues",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/flowcraft.git",
		"directory": "packages/tools"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./adapters": {
			"types": "./dist/adapters/index.d.mts",
			"import": "./dist/adapters/index.mjs"
		}
	},
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@anthropic-ai/sdk": "^0.98.0",
		"@langchain/core": "^1.1.48",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^4.1.7",
		"ai": "^6.0.191",
		"flowcraft": "workspace:*",
		"openai": "^6.39.0",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"@anthropic-ai/sdk": ">=0.30.0",
		"@langchain/core": ">=0.3.0",
		"ai": ">=4.0.0",
		"flowcraft": ">=2.10.0",
		"openai": ">=4.0.0"
	},
	"peerDependenciesMeta": {
		"@anthropic-ai/sdk": {
			"optional": true
		},
		"@langchain/core": {
			"optional": true
		},
		"ai": {
			"optional": true
		},
		"flowcraft": {
			"optional": true
		},
		"openai": {
			"optional": true
		}
	}
}
