{
	"name": "@flowcraft/opentelemetry-middleware",
	"version": "1.0.3",
	"description": "OpenTelemetry middleware for Flowcraft workflows",
	"homepage": "https://flowcraft.js.org",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@opentelemetry/sdk-trace-base": "^2.7.1",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^4.1.7",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"@opentelemetry/api": "^1.8.0",
		"flowcraft": "^2.10.1"
	}
}
