		"tldraw": "^5.0.1",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"peerDependencies": {
		"flowcraft": "^2.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tldraw": "^3.0.0"
