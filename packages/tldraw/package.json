{
	"name": "@flowcraft/tldraw",
	"version": "0.1.0",
	"description": "tldraw-based visual workflow editor and execution viewer for flowcraft",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/flowcraft.git"
	},
